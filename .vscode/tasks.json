{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ng serve",
      "type": "shell",
      "command": "npm",
      "args": ["start"],
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "env": {
          "PATH": "/home/arthur/.nvm/versions/node/v24.14.0/bin:${env:PATH}"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Building\\.\\.\\.",
          "endsPattern": "Compiled successfully|Application bundle generation complete"
        }
      }
    }
    ,
    {
      "label": "stop ng serve",
      "type": "shell",
      "command": "echo 'ng serve stopped'",
      "presentation": {
        "reveal": "never"
      },
      "problemMatcher": []
    }
  ]
}
