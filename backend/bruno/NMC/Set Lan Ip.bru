meta {
  name: Set Lan Ip
  type: http
  seq: 10
}

put {
  url: {{baseUrl}}/nmc/lan-ip
  body: json
  auth: none
}

body:json {
  {
    "Address": "192.168.1.1",
    "Netmask": "255.255.255.0",
    "DHCPEnable": true,
    "DHCPMinAddress": "192.168.1.1",
    "DHCPMaxAddress": "192.168.1.1",
    "LeaseTime": 86400
  }
}
